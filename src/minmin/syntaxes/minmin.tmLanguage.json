{
  "name": "minmin",
  "scopeName": "source.minmin",
  "fileTypes": [
    ".min"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.minmin",
      "match": "\\b(and|break|call|char|def|elif|else|if|int|not|or|print|return|use|while|xor)\\b"
    },
    {
      "name": "string.quoted.double.minmin",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    },
    {
      "name": "string.quoted.single.minmin",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "include": "#string-character-escape"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "#",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.minmin"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.minmin"
        }
      ]
    },
    "string-character-escape": {
      "name": "constant.character.escape.minmin",
      "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.|$)"
    }
  }
}
